# --- Required ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Optional ---
# Override the model if you want to test against another Claude variant.
ANTHROPIC_MODEL=claude-sonnet-4-5

# Where to keep the SQLite database. Defaults to ./embrace.db at repo root.
DATABASE_URL=sqlite:///./embrace.db

# How long to wait on web research before falling back to name-only scoring.
RESEARCH_TIMEOUT_SECONDS=30

# Total budget per scoring run.
SCORING_TIMEOUT_SECONDS=60

# How many web_search rounds the research agent is allowed.
WEB_SEARCH_MAX_USES=5

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
